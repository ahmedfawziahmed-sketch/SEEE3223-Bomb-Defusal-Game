#include "stm32f10x.h"

#define I2C_SLAVE_ADDR 0x4E 

void I2C1_Init(void) {
    RCC->APB2ENR |= RCC_APB2ENR_IOPBEN | RCC_APB2ENR_AFIOEN;
    RCC->APB1ENR |= RCC_APB1ENR_I2C1EN;
    
    GPIOB->CRL &= ~(0xFF << 24);
    GPIOB->CRL |= (0xFF << 24);
    
    I2C1->CR2 = 8;           
    I2C1->CCR = 40;          
    I2C1->TRISE = 9;         
    I2C1->CR1 |= I2C_CR1_PE; 
}

void I2C1_SendByte(uint8_t data) {
    I2C1->CR1 |= I2C_CR1_START;             
    while (!(I2C1->SR1 & I2C_SR1_SB));       
    
    I2C1->DR = I2C_SLAVE_ADDR;               
    while (!(I2C1->SR1 & I2C_SR1_ADDR));     
    (void)I2C1->SR2;                         
    
    I2C1->DR = data;                         
    while (!(I2C1->SR1 & I2C_SR1_TXE));      
    
    I2C1->CR1 |= I2C_CR1_STOP;               
}

void LCD_WriteNibble(uint8_t nibble, uint8_t rs) {
    uint8_t data = (nibble & 0xF0) | rs | 0x08; 
    I2C1_SendByte(data | 0x04);                 
    for (volatile int i = 0; i < 500; i++);
    I2C1_SendByte(data & ~0x04);                
    for (volatile int i = 0; i < 500; i++);
}

void LCD_SendCommand(uint8_t cmd) {
    LCD_WriteNibble(cmd & 0xF0, 0); 
    LCD_WriteNibble((cmd << 4) & 0xF0, 0); 
}

void LCD_SendData(uint8_t data) {
    LCD_WriteNibble(data & 0xF0, 1); 
    LCD_WriteNibble((data << 4) & 0xF0, 1);
}

void LCD_Init(void) {
    for (volatile int i = 0; i < 50000; i++); 
    LCD_WriteNibble(0x30, 0);
    LCD_WriteNibble(0x30, 0);
    LCD_WriteNibble(0x30, 0);
    LCD_WriteNibble(0x20, 0); 
    
    LCD_SendCommand(0x28); 
    LCD_SendCommand(0x0C); 
    LCD_SendCommand(0x06); 
    LCD_SendCommand(0x01); 
    for (volatile int i = 0; i < 50000; i++);
}

void LCD_Print(char *str) {
    while (*str) {
        LCD_SendData((uint8_t)(*str++));
    }
}
